# OpenLogs configuration.
# Copy to .env and adjust. All variables are optional except OPENLOGS_SECRET_KEY.

# Public domain that Caddy will serve. Set this to your own domain — no need
# to edit the Caddyfile directly. (default: logs.example.com)
OPENLOGS_URL=logs.example.com

# REQUIRED: secret used to sign session cookies. The server exits if unset.
# Generate a strong value, e.g.:  openssl rand -hex 32
OPENLOGS_SECRET_KEY=superdupersecretkey

# Path to the SQLite database file. (default: openlogs.db)
# In Docker this is set to /data/openlogs.db so it lands on the mounted volume.
OPENLOGS_DB_PATH=openlogs.db

# HTTP listen port inside the container. (default: 8080)
OPENLOGS_PORT=8080

# Host port to bind when running behind a local reverse proxy (nginx, Traefik, etc.)
# instead of Caddy. Uncomment the `ports:` block in docker-compose.yml to use this.
# HOST_PORT=8080

# UI theme: modern | terminal (default: modern)
OPENLOGS_THEME=modern

# Delete logs older than this many days. Positive integer. (default: 30)
OPENLOGS_RETENTION_DAYS=30

# Directory of custom .css overrides applied after the built-in theme.
# (default: web/static/custom; Docker sets this to /custom)
OPENLOGS_CUSTOM_CSS_DIR=web/static/custom

# Optional admin bootstrap. If BOTH are set, the server creates this user on
# startup when it does not already exist (idempotent; safe across restarts).
# Leave unset to manage users only via `openlogs create-user`.
# Password must be at least 8 characters.
#OPENLOGS_ADMIN_EMAIL=admin@example.com
#OPENLOGS_ADMIN_PASSWORD=change-me-please
